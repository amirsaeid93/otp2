<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.WeightController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label fx:id="welcomeLabel" text=""/>

    <HBox spacing="10.0" alignment="CENTER">
        <Button fx:id="btnEnglish" onAction="#onButton1Click" text="English"/>
        <Button fx:id="btnFrench" onAction="#onButton2Click" text="Française"/>
        <!-- Corrected fx:id to match controller -->
        <Button fx:id="btnUrdu" onAction="#onButton3Click" text="اردو"/>
        <Button fx:id="btnVietnamese" onAction="#onButton4Click" text="Tiếng Việt"/>
    </HBox>

    <HBox spacing="10.0" alignment="CENTER">
        <Label fx:id="lblWeight" text=""/>
        <TextField fx:id="weightField"/>
    </HBox>

    <HBox spacing="10.0" alignment="CENTER">
        <Label fx:id="lblHeight" text=""/>
        <TextField fx:id="heightField"/>
    </HBox>

    <Button fx:id="btnCalculate" onAction="#onCalculateBMI" text=""/>

    <Label fx:id="lblResult" text=""/>
    <Label fx:id="lblInvalid" text="" style="-fx-text-fill: red;"/>

</VBox>